# ================================================
# CCA Registration Platform — Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ================================================

# Database (Supabase PostgreSQL)
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://chinese-school-platform.vercel.app"

# Stripe (use sk_test_ for dev, sk_live_ for production)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal (use sandbox for dev, live for production)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@charlottechineseacademy.org"
ADMIN_BACKUP_EMAIL="alg.herbs@gmail.com"

# Supabase Storage (for volunteer photo uploads)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cron job authentication
CRON_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="https://chinese-school-platform.vercel.app"
