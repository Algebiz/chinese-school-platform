generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  PARENT
  ADMIN
  SUPER_ADMIN
}

enum ClassType {
  CHINESE
  ARTS
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  TRANSFERRED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
}

enum ExamType {
  YCT
  HSK
}

enum ExamRegistrationStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  REJECTED
  CANCELLED
}

// ─── NextAuth tables ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain ──────────────────────────────────────────────────────────────

model Family {
  id        String    @id @default(cuid())
  phone     String?
  address   String?
  users     User[]
  students  Student[]
  volunteerDeposits VolunteerDeposit[]
  volunteerClaims   VolunteerClaim[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PARENT)
  phone         String?
  familyId      String?
  family        Family?   @relation(fields: [familyId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Student {
  id          String       @id @default(cuid())
  name        String
  nameEn      String?
  birthDate   DateTime?
  grade       String?
  gender      String?
  notes       String?
  familyId    String
  family      Family       @relation(fields: [familyId], references: [id])
  enrollments        Enrollment[]
  waitlists          Waitlist[]
  nextClassOverrides StudentNextClassOverride[]
  examRegistrations  ExamRegistration[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  email     String?
  phone     String?
  bioEn     String?
  bioZh     String?
  photoUrl  String?
  classes   Class[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id            String       @id @default(cuid())
  name          String
  nameEn        String?
  type          ClassType
  description   String?
  descriptionZh String?
  isActive      Boolean      @default(true)
  teacherId     String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  schedule    Json
  capacity    Int
  fee         Decimal      @db.Decimal(10, 2)
  year        String
  enrollments        Enrollment[]
  waitlists          Waitlist[]
  nextClassOverrides StudentNextClassOverride[]
  textbooks          Textbook[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Textbook {
  id            String   @id @default(cuid())
  classId       String
  name          String
  nameZh        String
  description   String?
  descriptionZh String?
  price         Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  class           Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollmentBooks EnrollmentTextbook[]
}

model EnrollmentTextbook {
  id           String   @id @default(cuid())
  enrollmentId String
  textbookId   String
  price        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  textbook   Textbook   @relation(fields: [textbookId], references: [id])

  @@unique([enrollmentId, textbookId])
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id])
  classId   String
  class     Class            @relation(fields: [classId], references: [id])
  status    EnrollmentStatus @default(PENDING)
  payments  Payment[]
  textbooks EnrollmentTextbook[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, classId])
}

model Payment {
  id             String        @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment    @relation(fields: [enrollmentId], references: [id])
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  stripeIntentId String?
  paypalOrderId  String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Waitlist {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  position  Int
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([studentId, classId])
}

model AdjustmentLog {
  id         String   @id @default(cuid())
  studentId  String
  adminId    String
  fromClassId String?
  toClassId  String?
  reason     String
  createdAt  DateTime @default(now())
}

model AcademicYearConfig {
  id                    String    @id @default(cuid())
  academicYear          String    @unique  // e.g. "2025-2026" (the year that is ending)
  nextYear              String            // e.g. "2026-2027" (the year being enrolled into)
  reEnrollmentOpenDate  DateTime
  newEnrollmentOpenDate DateTime
  isActive              Boolean   @default(true)
  volunteerDepositAmount   Decimal?  @db.Decimal(10,2)
  volunteerClaimDeadline   DateTime?
  volunteerDepositRequired Boolean   @default(true)
  createdAt             DateTime  @default(now())
}

model StudentNextClassOverride {
  id           String   @id @default(cuid())
  studentId    String
  academicYear String   // the NEW year being enrolled into
  classId      String
  adminId      String
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, academicYear])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(UNREAD)
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ExamSession {
  id                   String             @id @default(cuid())
  examType             ExamType
  level                Int
  examDate             DateTime
  registrationDeadline DateTime
  location             String
  locationZh           String
  fee                  Decimal            @db.Decimal(10, 2)
  capacity             Int
  academicYear         String
  isActive             Boolean            @default(true)
  notes                String?
  notesZh              String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  registrations        ExamRegistration[]
}

model ExamRegistration {
  id                    String                 @id @default(cuid())
  examSessionId         String
  examSession           ExamSession            @relation(fields: [examSessionId], references: [id])
  studentId             String
  student               Student                @relation(fields: [studentId], references: [id])
  status                ExamRegistrationStatus @default(PENDING_PAYMENT)
  paymentMethod         PaymentMethod?
  stripePaymentIntentId String?
  paypalOrderId         String?
  paidAt                DateTime?
  amount                Decimal?               @db.Decimal(10, 2)
  confirmedAt           DateTime?
  confirmedBy           String?
  rejectedAt            DateTime?
  rejectedBy            String?
  rejectionReason       String?
  studentNameZh         String
  studentNameEn         String?
  studentDob            DateTime?
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([examSessionId, studentId])
}

model SystemSettings {
  id            String   @id @default(cuid())
  schoolNameZh  String   @default("夏洛特中文学校")
  schoolNameEn  String   @default("Charlotte Chinese Academy")
  contactEmail  String   @default("")
  contactPhone  String   @default("")
  updatedAt     DateTime @updatedAt
  updatedBy     String?
}

enum DepositStatus {
  PENDING
  PAID
  CLAIM_PENDING
  CLAIM_APPROVED
  REFUNDED
  FORFEITED
}

enum ClaimStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model VolunteerService {
  id            String   @id @default(cuid())
  name          String
  nameZh        String
  description   String?
  descriptionZh String?
  academicYear  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claims VolunteerClaim[]
}

model VolunteerDeposit {
  id                    String         @id @default(cuid())
  familyId              String
  academicYear          String
  amount                Decimal        @db.Decimal(10, 2) @default(100)
  status                DepositStatus  @default(PENDING)
  paidAt                DateTime?
  paymentMethod         PaymentMethod?
  stripePaymentIntentId String?
  paypalOrderId         String?
  forfeitedAt           DateTime?
  refundedAt            DateTime?
  refundedBy            String?
  refundNotes           String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  family Family           @relation(fields: [familyId], references: [id])
  claims VolunteerClaim[]

  @@unique([familyId, academicYear])
}

model VolunteerClaim {
  id              String      @id @default(cuid())
  depositId       String
  familyId        String
  serviceId       String
  academicYear    String
  description     String      @db.Text
  photoUrl        String?
  submittedAt     DateTime    @default(now())
  status          ClaimStatus @default(PENDING_REVIEW)
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  deposit VolunteerDeposit @relation(fields: [depositId], references: [id])
  family  Family           @relation(fields: [familyId], references: [id])
  service VolunteerService @relation(fields: [serviceId], references: [id])
}
